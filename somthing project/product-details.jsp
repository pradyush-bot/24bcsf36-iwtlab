<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="com.nothing.dao.ProductDAO, com.nothing.model.Product" %>
<%
    String ctx = request.getContextPath();
    int id = Integer.parseInt(request.getParameter("id"));
    ProductDAO dao = new ProductDAO();
    Product p = dao.getProductById(id);

    String imgSrc;
    switch (p.getId()) {
    case 1:  imgSrc = "https://media-ik.croma.com/prod/https://media.tatacroma.com/Croma%20Assets/Communication/Mobiles/Images/321832_0_eqsewhhOi.png?updatedAt=1772794684510"; break;
    case 2:  imgSrc = "data:image/jpeg;base64,"; break;
    case 3:  imgSrc = "https://fdn2.gsmarena.com/vv/bigpic/nothing-phone-3a-pro-new.jpg"; break;
    case 4:  imgSrc = "https://m.media-amazon.com/images/I/51B5renZLJL._AC_UF1000,1000_QL80_.jpg"; break;
    case 5:  imgSrc = "data:image/jpeg;base64,"; break;
    default: imgSrc = "data:image/jpeg;base64,"; break;
}
