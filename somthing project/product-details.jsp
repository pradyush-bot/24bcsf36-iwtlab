<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= p.getName() %> — NothingStore</title>
    <link rel="stylesheet" href="<%=ctx%>/css/style.css">
    <style>
        /* TOAST */
        .toast {
            position: fixed; bottom: 40px; right: 40px;
            background: black; color: white;
            font-size: 12px; letter-spacing: 1px;
            padding: 14px 24px; z-index: 9999;
            opacity: 0; transform: translateY(20px);
            transition: all 0.3s ease; pointer-events: none;
        }
        .toast.show { opacity: 1; transform: translateY(0); }
        .toast .toast-check { margin-right: 8px; }
    </style>
</head>

<body>

<!-- NAVBAR -->
<header>
<nav class="navbar">
    <div class="logo">
        <a href="<%=ctx%>/index.jsp">NOTHING</a>
    </div>
    <nav id="navLinks">
        <a href="<%=ctx%>/index.jsp">Home</a>
        <a href="<%=ctx%>/products.jsp">Products</a>
        <a href="<%=ctx%>/cart.jsp" id="nav-cart-link" style="position:relative;">
            Cart
            <span id="nav-cart-badge" style="
                display:none;
                position:absolute;
                top:-8px;right:-12px;
                background:black;color:white;
                border-radius:50%;width:16px;height:16px;
                font-size:10px;line-height:16px;text-align:center;
            "></span>
        </a>
    </nav>
</nav>
</header>

<!-- TOAST -->
<div class="toast" id="toast"><span class="toast-check">✓</span><span id="toast-msg"></span></div>

<section class="hero" style="height:auto; padding:120px 40px;">

    <img src="<%= imgSrc %>" alt="<%= p.getName() %>" style="max-width:300px;">

    <h1><%= p.getName() %></h1>
    <p><%= p.getDescription() %></p>

    <h2>&#8377;<%= String.format("%,.0f", p.getPrice()) %></h2>

   <%
    String buyLink;
    switch (p.getId()) {
        case 1:  buyLink = "https://www.flipkart.com/nothing-phone-4a-pro-silver-256-gb/p/itm4d004931f8d69?pid=MOBHK7DDCAKYPKFG&lid=LSTMOBHK7DDCAKYPKFGIQ5LTV&marketplace=FLIPKART&q=nothing+4a+pro&store=tyy%2F4io&srno=s_1_1&otracker=AS_QueryStore_OrganicAutoSuggest_1_4_na_na_na&otracker1=AS_QueryStore_OrganicAutoSuggest_1_4_na_na_na&fm=organic&iid=140c3173-2725-45b1-85b7-347523c83ddd.MOBHK7DDCAKYPKFG.SEARCH&ppt=hp&ppn=homepage&ssid=je962agya80000001776841214188&qH=b3819e7e6d7e8d4e&ov_redirect=true"; break;
        case 2:  buyLink = "https://www.flipkart.com/nothing-phone-3a-lite-black-128-gb/p/itm103dc27c53435?pid=MOBHHKYZGVHF7TSF&lid=LSTMOBHHKYZGVHF7TSF6F3Q5C&marketplace=FLIPKART&q=nothing+3a+mobile+5g&store=tyy%2F4io&spotlightTagId=default_BestsellerId_tyy%2F4io&srno=s_1_1&otracker=AS_QueryStore_OrganicAutoSuggest_1_10_na_na_ps&otracker1=AS_QueryStore_OrganicAutoSuggest_1_10_na_na_ps&fm=search-autosuggest&iid=43e5ef44-1ba9-4c8c-9015-496d56015630.MOBHHKYZGVHF7TSF.SEARCH&ppt=sp&ppn=sp&ssid=akitzi60n40000001776841300659&qH=05bd87e76d821c1e&ov_redirect=true"; break;
        case 3:  buyLink = "https://www.flipkart.com/cmf-nothing-phone-2-pro-light-green-256-gb/p/itm46a119f176627?pid=MOBHAUHA6X5YWPBP&lid=LSTMOBHAUHA6X5YWPBPVY1EW2&marketplace=FLIPKART&q=nothing+2a+pro+5g&store=tyy%2F4io&srno=s_1_1&otracker=AS_Query_OrganicAutoSuggest_2_10_na_na_ps&otracker1=AS_Query_OrganicAutoSuggest_2_10_na_na_ps&fm=search-autosuggest&iid=34f657cd-7361-447b-9c55-d46039ddfbf1.MOBHAUHA6X5YWPBP.SEARCH&ppt=sp&ppn=sp&ssid=u2pvk618wg0000001776841358004&qH=1c5fb240f74d4e17&ov_redirect=true"; break;
        case 4:  buyLink = "https://www.flipkart.com/nothing-ear-a-2024-chatgpt-compatible-hi-res-audio-ldac-bluetooth/p/itm8da590d5343d2?pid=ACCGZ6Q3X3W3TZWX&lid=LSTACCGZ6Q3X3W3TZWXTHSA9B&marketplace=FLIPKART&q=nothing+earbuds+pro+&store=0pm%2Ffcn&srno=s_1_1&otracker=search&otracker1=search&fm=Search&iid=acbf3ab2-bb49-40a1-b619-d966011ddec6.ACCGZ6Q3X3W3TZWX.SEARCH&ppt=sp&ppn=sp&ssid=40a6tuc64g0000001776841416703&qH=af8bce8527753f79&ov_redirect=true&ov_redirect=true"; break;
        case 5:  buyLink = "https://www.flipkart.com/nothing-ear-stick-bluetooth/p/itm6b61ae506f190?pid=ACCGEDSQM6ZV3CAE&lid=LSTACCGEDSQM6ZV3CAEMN7RHO&marketplace=FLIPKART&q=nothing+earbuds&store=0pm%2Ffcn%2F821%2Fa7x%2F2si&srno=s_1_6&otracker=AS_QueryStore_OrganicAutoSuggest_1_11_na_na_na&otracker1=AS_QueryStore_OrganicAutoSuggest_1_11_na_na_na&fm=search-autosuggest&iid=983208a1-b20d-458e-9718-15a820db0dfa.ACCGEDSQM6ZV3CAE.SEARCH&ppt=sp&ppn=sp&ssid=f0bbggjrwg0000001776841535488&qH=85428eac10142c00&ov_redirect=true&ov_redirect=true"; break;
        default: buyLink = "https://www.flipkart.com/cmf-nothing-buds-2-48-db-hybrid-anc-ultra-bass-technology-2-0-55-hrs-playtime-bluetooth/p/itm4ff1e90dcc468?pid=ACCHBK3P5SBVDNEE&marketplace=FLIPKART&lid=LSTACCHBK3P5SBVDNEEHFWWZI&q=cmf+by+nothing+earbuds+&fm=Search&pageUID=1776841471121"; break;
    }
%>

<button id="add-to-cart-btn" onclick="addToCart()">
    Add to Cart &rarr;
</button>

<script>
// ── product data injected by server ──────────────────────────
const PRODUCT = {
    id: <%= p.getId() %>,
    name: "<%= p.getName().replace("\"", "\\\"") %>",
    price: <%= (int) p.getPrice() %>,
    image: "<%= imgSrc %>"
};

// ── cart helpers ─────────────────────────────────────────────
function getCart()      { return JSON.parse(localStorage.getItem('nothingCart') || '[]'); }
function saveCart(c)    { localStorage.setItem('nothingCart', JSON.stringify(c)); }

function updateBadge() {
    const total = getCart().reduce((s, i) => s + i.qty, 0);
    const badge = document.getElementById('nav-cart-badge');
    if (badge) {
        badge.textContent = total;
        badge.style.display = total > 0 ? 'inline-block' : 'none';
    }
}

function showToast(msg) {
    const t = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
}

function addToCart() {
    const cart  = getCart();
    const idx   = cart.findIndex(i => i.id === PRODUCT.id);
    if (idx >= 0) {
        cart[idx].qty += 1;
    } else {
        cart.push({ ...PRODUCT, qty: 1 });
    }
    saveCart(cart);
    updateBadge();
    showToast(PRODUCT.name + ' added to cart');

    // Button feedback
    const btn = document.getElementById('add-to-cart-btn');
    btn.textContent = 'Added! →';
    btn.style.background = '#333';
    setTimeout(() => {
        btn.textContent = 'Add to Cart →';
        btn.style.background = '';
    }, 1800);
}

// Init badge on page load
updateBadge();
</script>

</section>

<footer>
    <p>&copy; 2026 something Technology Ltd.</p>
</footer>

<script src="<%=ctx%>/js/script.js"></script>

</body>
</html>