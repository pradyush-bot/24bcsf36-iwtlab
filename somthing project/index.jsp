<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%
    String userName = (String) session.getAttribute("userName");
    String ctx = request.getContextPath();
%>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Something</title>

<link rel="stylesheet" href="<%=ctx%>/css/style.css">
</head>

<body>

<!-- NAVBAR -->
<header>
<nav class="navbar">

    <div class="logo">
        <a href="<%=ctx%>/index.jsp">SOMETHING</a>
    </div>

    <nav>
        <a href="<%=ctx%>/index.jsp">Home</a>
        <a href="<%=ctx%>/products.jsp">Products</a>
        <a href="<%=ctx%>/community.jsp">Community</a>
        <a href="<%=ctx%>/about.jsp">About</a>
        <a href="<%=ctx%>/cart.jsp" id="nav-cart-link" style="position:relative;">
            Cart
            <span id="nav-cart-badge" style="
                display:none;
                position:absolute;
                top:-8px;right:-12px;
                background:black;color:white;
                border-radius:50%;width:16px;height:16px;
                font-size:10px;line-height:16px;text-align:center;
            "></span>
        </a>

        <% if (userName != null) { %>
            <a href="<%=ctx%>/profile.jsp">Profile</a>
            <a href="<%=ctx%>/LogoutServlet">Logout</a>
        <% } else { %>
            <a href="<%=ctx%>/login.jsp">Login</a>
        <% } %>
    </nav>

</nav>

    <div class="menu-toggle" id="hamburger">
        <span></span><span></span><span></span>
    </div>

</header>
<!-- ===== HERO (ADVANCED SPLIT LAYOUT) ===== -->
<section class="hero">

    <div class="hero-content">

        <h1>
            Design.<br>Redefined.
        </h1>

        <p>
            Iconic transparency meets next-level performance.<br>
            Minimal. Powerful. Nothing.
        </p>

        <div style="margin-top:30px; display:flex; gap:15px; justify-content:center; flex-wrap:wrap;">

            <% if (userName != null) { %>
                <button onclick="location.href='<%=ctx%>/products.jsp'">
                    Shop Now →
                </button>
            <% } else { %>
                <button onclick="location.href='<%=ctx%>/login.jsp'">
                    Login to Shop →
                </button>
            <% } %>

            <button onclick="location.href='<%=ctx%>/signup.jsp'">
                Create Account →
            </button>

        </div>

    </div>

</section>

<!-- ===== FEATURE GRID (LIKE NOTHING SITE) ===== -->
<section class="products">

    <h2>Latest Products</h2>

    <div class="product-grid">

        <div class="card">
            <img src="data:image/jpeg;base64," alt="Phone">
            <h3>Phone (2)</h3>
            <p>Flagship performance with iconic design</p>
            <button onclick="location.href='<%=ctx%>/products.jsp'">Explore →</button>
        </div>

        <div class="card">
            <img src="data:image/jpeg;base64,">
            <h3>Ear (2)</h3>
            <p>Wireless audio, redefined</p>
            <button onclick="location.href='<%=ctx%>/products.jsp'">Explore →</button>
        </div>

        <div class="card">
            <img src="data:image/jpeg;base64," alt="Phone">
            <h3>Phone (2a)</h3>
            <p>Affordable power, same design DNA</p>
            <button onclick="location.href='<%=ctx%>/products.jsp'">Explore →</button>
        </div>

    </div>

</section>

<!-- ===== MID CTA (PREMIUM SECTION) ===== -->
<section class="hero" style="height:70vh;">

    <h1 style="font-size:50px;">
        Built for the future.
    </h1>

    <p style="margin-top:15px;">
        Join the ecosystem that redefines tech.
    </p>

    <div style="margin-top:25px;">
        <button onclick="location.href='<%=ctx%>/signup.jsp'">
            Get Started →
        </button>
    </div>

</section>

<!-- ===== FOOTER ===== -->
<footer>

    <p>© 2026 Something Technology Ltd.</p>

</footer>

<script src="<%=ctx%>/js/script.js"></script>
<script>
(function() {
    const cart  = JSON.parse(localStorage.getItem('nothingCart') || '[]');
    const total = cart.reduce(function(s, i) { return s + i.qty; }, 0);
    const badge = document.getElementById('nav-cart-badge');
    if (badge && total > 0) {
        badge.textContent = total;
        badge.style.display = 'inline-block';
    }
})();
</script>

</body>
</html>